<hr>
<details class="gicons">
<summary><strong>Іконки</strong></summary>
<div style="overflow-y: scroll; height: 200px;" id="gicons_list">
    <% Dir.glob('public/gicon/*.*') do |gicon| %>
        <img loading="lazy" src="<%= gicon.gsub('public', '') %>" class="gicon_list"></img>
    <% end %>
    </div>
</details>
<%= form_with model: @message, local: true do |form| %>
Ім'я отримувача:
<% if @message.reciever != nil %>
  <%= form.text_field :reciever, :style => 'display:block;width:100%;', :value => @message.reciever.name %>
<% else %>
  <%= form.text_field :reciever, :style => 'display:block;width:100%;' %>
<% end %>
Текст:
  <%= form.text_area :content, :rows => 10, :dir => "auto", :style => 'display:block;width:100%;', :oninput => "doRender()", :value => @message.content %>
  <%= form.file_field :pic, :accept => "image/*,.mp4,.mov,.hevc,.mp3", :style => "display:inline;" %>
  <%= form.submit :value => "Завантажити медіа", data: {disable_with: "Завантажити медіа"}, :style => "display:inline;" %>
  <%= form.submit :value => "Відправити", :style => "display:block;" %>
<% end %>

<%= link_to "Markdown", "/markdown", target: "_blank" %> Preview:
<hr>


<div id="display" dir="auto">
</div>

<%= javascript_tag nonce: true, type: 'application/javascript' do %>

function doRender() {
  var converter = new showdown.Converter();
  converter.setFlavor('github');
  var text      = document.getElementById("message_content").value;
  var html      = converter.makeHtml(text);
  document.getElementById("display").innerHTML = html;
}
doRender();

function addGicon (event) {
  if (event.target.classList.contains('gicon_list')) {
    var a = document.createElement('a');
    a.href = event.target.src;
    var gicon = document.createElement("img");
    gicon.classList.add("gicon");
    gicon.src = a.pathname;
    var field = document.getElementById("message_content");
    var startPos = field.selectionStart;
    var endPos = field.selectionEnd;
    field.value = field.value.substring(0, startPos)
            + gicon.outerHTML
            + field.value.substring(endPos, field.value.length);
    doRender();
  }
}
document.querySelector('#gicons_list').addEventListener('click', addGicon)
<% end %>
